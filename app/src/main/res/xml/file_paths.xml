<!-- Backs IcsShare's FileProvider: only cacheDir/exports/ (the disposable .ics export
     directory) is exposed to other apps via content:// URIs; nothing else in the app's
     storage is reachable through this provider. -->
<paths>
    <cache-path name="exports" path="exports/" />
</paths>
