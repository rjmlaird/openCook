+++ b/app/src/main/java/com/food/opencook/util/IcsExport.kt
@@ -0,0 +1,89 @@
+/*
+ *  openCook
+ *  Copyright (C) 2026 olie.xdev <olie.xdeveloper@googlemail.com>
+ *
